# ── Server ────────────────────────────────────────────────────────────────────
PORT=4064

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname

# ── Auth (shared with WorksBuddy SSO) ────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8
SSO_API_URL=https://api-accounts.worksbuddy.ai

# ── API Gateway key (for /api/* routes) ──────────────────────────────────────
WB_API_KEY=your-wb-api-key

# ── Bright Data ───────────────────────────────────────────────────────────────
BRIGHT_DATA_API_KEY=your-brightdata-api-key
BRIGHT_DATA_PROFILE_DATASET_ID=gd_l1viktl72bvl7bjuj0
BRIGHT_DATA_COMPANY_DATASET_ID=gd_l1viktnm16wn69zjq
BD_REQUEST_TIMEOUT=90

# ── Email finders ─────────────────────────────────────────────────────────────
HUNTER_API_KEY=your-hunter-api-key
APOLLO_API_KEY=your-apollo-api-key
VALIDEMAIL_TOKEN=your-validemail-token

# ── LLM (HuggingFace Router — primary LLM) ───────────────────────────────────
# Get from: https://huggingface.co/settings/tokens → New token (type: Read)
HF_TOKEN=your-hf-token
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── Email Waterfall ───────────────────────────────────────────────────────────
DROPCONTACT_API_KEY=
PDL_API_KEY=
ZEROBOUNCE_API_KEY=

# ── Ably — real-time lead progress events ────────────────────────────────────
ABLY_API_KEY=your-ably-api-key

# ── SerpAPI ───────────────────────────────────────────────────────────────────
SERPAPI_KEY=your-serpapi-key

# ── Public server URL (BrightData webhook delivery) ──────────────────────────
APP_URL=https://leadenrichment-production-5b78.up.railway.app

# ── Webhook security ──────────────────────────────────────────────────────────
LEAD_WEBHOOK_SECRET=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Queue Worker Tuning ───────────────────────────────────────────────────────
LEAD_WORKER_COUNT=4
LEAD_WORKER_MAX=12
CHUNK_MIN=5
CHUNK_MAX=100
CHUNK_DEFAULT=25
CHUNK_REFRESH_SECS=30
QUEUE_MAX_ATTEMPTS=3
AUTOSCALE_INTERVAL_SECS=15
QUEUE_SCALE_UP_DEPTH=10
QUEUE_SCALE_DOWN_DEPTH=2

# ── LIO — downstream enrichment receiver ─────────────────────────────────────
LIO_RECEIVE_URL=https://api-lio.worksbuddy.ai/api/enrich/receive
LIO_TOKEN=your-lio-token

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000
