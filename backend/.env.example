# ── Server ────────────────────────────────────────────────────────────────────
PORT=4064

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://lead_enrichment:your-db-password@your-db-host:5432/lead_enrichment

# ── Auth (shared with WorksBuddy SSO) ────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8
SSO_API_URL=https://api-accounts.worksbuddy.ai

# ── API Gateway key (for /api/* routes) ──────────────────────────────────────
WB_API_KEY=your-wb-api-key

# ── Bright Data ───────────────────────────────────────────────────────────────
# Get from: https://brightdata.com/cp/api_tokens
BRIGHT_DATA_API_KEY=your-brightdata-api-key
BRIGHT_DATA_PROFILE_DATASET_ID=your-profile-dataset-id
BRIGHT_DATA_COMPANY_DATASET_ID=your-company-dataset-id
# seconds for sync /scrape calls
BD_REQUEST_TIMEOUT=90

# ── Email finders ─────────────────────────────────────────────────────────────
# Apollo.io: https://developer.apollo.io
APOLLO_API_KEY=your-apollo-api-key
# ValidEmail.net: https://api.ValidEmail.net
VALIDEMAIL_TOKEN=your-validemail-token

# ── LLM (HuggingFace — primary AI for CRM brief, outreach, scoring) ─────────
# Get from: https://huggingface.co/settings/tokens → New token (type: Read)
HF_TOKEN=your-huggingface-token
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── Email Waterfall — P4 additions ───────────────────────────────────────────
# Dropcontact: https://dropcontact.com/api
DROPCONTACT_API_KEY=
# People Data Labs: https://www.peopledatalabs.com/
PDL_API_KEY=
# ZeroBounce: https://www.zerobounce.net/docs/
ZEROBOUNCE_API_KEY=

# ── Ably — real-time lead progress events ────────────────────────────────────
# Get from: https://ably.com/dashboard → Apps → API Keys
# Format: appId.keyId:keySecret
ABLY_API_KEY=your-ably-api-key

# ── SerpAPI — Google search enrichment ───────────────────────────────────────
# Get from: https://serpapi.com/manage-api-key
SERPAPI_KEY=your-serpapi-key

# ── Public server URL (auto-webhook for BrightData batch) ────────────────────
# Set to the publicly reachable base URL of this server (no trailing slash)
# When set, bulk enrichment jobs automatically use BrightData webhook delivery
# instead of polling workers — much faster for large batches
# Example: https://leadsapi.worksbuddy.ai
# Leave empty to use polling mode (local dev)
APP_URL=

# ── Webhook security ──────────────────────────────────────────────────────────
LEAD_WEBHOOK_SECRET=

# ── Fair Multi-Tenant Queue System ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# base worker pool size
LEAD_WORKER_COUNT=4
# autoscaler upper bound (default: LEAD_WORKER_COUNT * 3)
LEAD_WORKER_MAX=12
# min URLs per chunk (memory pressure)
CHUNK_MIN=5
# max URLs per chunk (free memory)
CHUNK_MAX=100
# fallback chunk size
CHUNK_DEFAULT=25
# how often to recompute chunk size
CHUNK_REFRESH_SECS=30
# retry attempts before chunk goes to DLQ
QUEUE_MAX_ATTEMPTS=3
# how often autoscaler checks queue depth
AUTOSCALE_INTERVAL_SECS=15
# work queue depth threshold to add a worker
QUEUE_SCALE_UP_DEPTH=10
# work queue depth threshold to remove a worker
QUEUE_SCALE_DOWN_DEPTH=2

# ── Queue Worker Tuning ───────────────────────────────────────────────────────
# Number of concurrent enrichment workers (default 4 → increased to 32)
LEAD_WORKER_COUNT=32
# Max URLs per chunk dispatched to a single worker
CHUNK_MAX=200
# Default chunk size when system load is moderate
CHUNK_DEFAULT=50
CHUNK_MIN=25

# ── LIO — downstream enrichment receiver ─────────────────────────────────────
LIO_RECEIVE_URL=https://api-lio.worksbuddy.ai/api/enrich/receive
LIO_TOKEN=your-lio-jwt-token

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000
