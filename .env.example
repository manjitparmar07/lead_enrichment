# ── Server ────────────────────────────────────────────────────────────────────
PORT=4064

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://lead_enrichment:password@172.105.58.70/lead_enrichment

# ── Auth (shared with WorksBuddy SSO) ────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8
SSO_API_URL=https://api-accounts.worksbuddy.ai

# ── API Gateway key (for /api/* routes) ──────────────────────────────────────
WB_API_KEY=wb-dev-key-2024

# ── Bright Data ───────────────────────────────────────────────────────────────
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_PROFILE_DATASET_ID=gd_l1viktl72bvl7bjuj0
BRIGHT_DATA_COMPANY_DATASET_ID=gd_l1viktnm16wn69zjq
BD_REQUEST_TIMEOUT=90          # seconds for sync /scrape calls (default 90)

# ── Email finders ─────────────────────────────────────────────────────────────
HUNTER_API_KEY=
APOLLO_API_KEY=

# ── LLM (for AI scoring + outreach generation) ───────────────────────────────
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Email Waterfall — P4 additions ───────────────────────────────────────────
# Dropcontact: https://dropcontact.com/api
DROPCONTACT_API_KEY=
# People Data Labs: https://www.peopledatalabs.com/
PDL_API_KEY=
# ZeroBounce: https://www.zerobounce.net/docs/
ZEROBOUNCE_API_KEY=

# ── Ably — real-time lead progress events ────────────────────────────────────
# Get from: https://ably.com/dashboard → Apps → API Keys
# Format: appId.keyId:keySecret
ABLY_API_KEY=

# ── Public server URL (auto-webhook for BrightData batch) ────────────────────
# Set to the publicly reachable base URL of this server (no trailing slash)
# When set, bulk enrichment jobs automatically use BrightData webhook delivery
# instead of polling workers — much faster for large batches
# Example: https://leadsapi.worksbuddy.ai
APP_URL=

# ── Webhook security ──────────────────────────────────────────────────────────
LEAD_WEBHOOK_SECRET=

# ── Fair Multi-Tenant Queue System ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
LEAD_WORKER_COUNT=4          # base worker pool size
LEAD_WORKER_MAX=12           # autoscaler upper bound (default: LEAD_WORKER_COUNT * 3)
CHUNK_MIN=5                  # min URLs per chunk (memory pressure)
CHUNK_MAX=100                # max URLs per chunk (free memory)
CHUNK_DEFAULT=25             # fallback chunk size
CHUNK_REFRESH_SECS=30        # how often to recompute chunk size
QUEUE_MAX_ATTEMPTS=3         # retry attempts before chunk goes to DLQ
AUTOSCALE_INTERVAL_SECS=15   # how often autoscaler checks queue depth
QUEUE_SCALE_UP_DEPTH=10      # work queue depth threshold to add a worker
QUEUE_SCALE_DOWN_DEPTH=2     # work queue depth threshold to remove a worker

# ── LIO — downstream enrichment receiver ─────────────────────────────────────
LIO_RECEIVE_URL=https://api-lio-worksbuddy.lbmdemo.com/api/enrich/receive

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000
